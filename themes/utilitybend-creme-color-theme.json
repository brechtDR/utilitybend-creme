    "terminal.background": "#f6f3ec",
    "terminal.foreground": "#222222",
    "terminal.ansiBlack": "#3a332a",
    "terminal.ansiRed": "#d83737",
    "terminal.ansiGreen": "#5d8a1c",
    "terminal.ansiYellow": "#a24c05",
    "terminal.ansiBlue": "#05618f",
    "terminal.ansiMagenta": "#7b5296",
    "terminal.ansiCyan": "#05618f",
    "terminal.ansiWhite": "#3a332a",
    "terminal.ansiBrightBlack": "#6b6355",
    "terminal.ansiBrightRed": "#d83737",
    "terminal.ansiBrightGreen": "#5d8a1c",
    "terminal.ansiBrightYellow": "#a24c05",
    "terminal.ansiBrightBlue": "#05618f",
    "terminal.ansiBrightMagenta": "#bc0376",
    "terminal.ansiBrightCyan": "#05618f",
    "terminal.ansiBrightWhite": "#222222",
    "terminalCursor.foreground": "#bc0376",

    "input.background": "#f6f3ec",
    "input.foreground": "#222222",
    "input.border": "#c5ba9f",
    "input.placeholderForeground": "#8a7e66",
    "inputOption.activeBorder": "#bc0376",

    "dropdown.background": "#f6f3ec",
    "dropdown.foreground": "#222222",
    "dropdown.border": "#c5ba9f",

    "button.background": "#bc0376",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#a00263",
    "button.secondaryBackground": "#e5dcc5",
    "button.secondaryForeground": "#222222",

    "badge.background": "#bc0376",
    "badge.foreground": "#ffffff",

    "scrollbar.shadow": "#00000022",
    "scrollbarSlider.background": "#00000018",
    "scrollbarSlider.hoverBackground": "#00000028",
    "scrollbarSlider.activeBackground": "#00000038",

    "minimap.selectionHighlight": "#bc037644",
    "minimap.findMatchHighlight": "#a24c0544",
    "minimapGutter.addedBackground": "#5d8a1c",
    "minimapGutter.deletedBackground": "#d83737",
    "minimapGutter.modifiedBackground": "#05618f",

    "peekView.border": "#bc0376",
    "peekViewEditor.background": "#efeadd",
    "peekViewEditor.matchHighlightBackground": "#a24c0533",
    "peekViewResult.background": "#eae3d2",
    "peekViewResult.fileForeground": "#222222",
    "peekViewResult.lineForeground": "#6b6355",
    "peekViewResult.matchHighlightBackground": "#a24c0533",
    "peekViewResult.selectionBackground": "#bc037622",
    "peekViewTitle.background": "#eae3d2",
    "peekViewTitleDescription.foreground": "#6b6355",
    "peekViewTitleLabel.foreground": "#222222",

    "gitDecoration.addedResourceForeground": "#5d8a1c",
    "gitDecoration.deletedResourceForeground": "#d83737",
    "gitDecoration.modifiedResourceForeground": "#05618f",
    "gitDecoration.untrackedResourceForeground": "#5d8a1caa",
    "gitDecoration.conflictingResourceForeground": "#f93d04",
    "gitDecoration.ignoredResourceForeground": "#a39a85",

    "debugToolBar.background": "#eae3d2",
    "debugIcon.breakpointForeground": "#eb007d",

    "focusBorder": "#bc037666",
    "foreground": "#222222",
    "descriptionForeground": "#6b6355",
    "selection.background": "#bc037644",
    "widget.shadow": "#00000022",
    "icon.foreground": "#6b6355",

    "notifications.background": "#f6f3ec",
    "notifications.foreground": "#222222",
    "notifications.border": "#c5ba9f",
    "notificationCenterHeader.background": "#eae3d2",

    "quickInput.background": "#f6f3ec",
    "quickInput.foreground": "#222222",
    "quickInputList.focusBackground": "#bc037622",

    "editorWidget.background": "#f6f3ec",
    "editorWidget.foreground": "#222222",
    "editorWidget.border": "#c5ba9f",
    "editorSuggestWidget.background": "#f6f3ec",
    "editorSuggestWidget.foreground": "#222222",
    "editorSuggestWidget.selectedBackground": "#bc037622",
    "editorSuggestWidget.highlightForeground": "#bc0376",

    "editorHoverWidget.background": "#f6f3ec",
    "editorHoverWidget.border": "#c5ba9f",

    "diffEditor.insertedTextBackground": "#5d8a1c1a",
    "diffEditor.removedTextBackground": "#d8373718"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#616161",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doctype, Prolog",
      "scope": [
        "meta.tag.sgml.doctype",
        "meta.tag.sgml",
        "comment.block.html"
      ],
      "settings": {
        "foreground": "#8a7e66"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.definition.tag",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#bc0376"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7b5296"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.function.misc.css",
        "support.function.calc.css",
        "support.function.gradient.css",
        "support.function.url.css",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#7b5296"
      }
    },
    {
      "name": "Booleans, Constants, Symbols",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.other.symbol",
        "support.constant"
      ],
      "settings": {
        "foreground": "#7b5296"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#5d8a1c"
      }
    },
    {
      "name": "Attribute Values (HTML/XML)",
      "scope": [
        "meta.attribute string",
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#5d8a1c"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#05618f"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "support.type.property-name",
        "support.type.property-name.css",
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#05618f"
      }
    },
    {
      "name": "CDATA, Char, Inserted",
      "scope": [
        "string.unquoted.cdata",
        "constant.character",
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#05618f"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#eb007d"
      }
    },
    {
      "name": "Attribute Names",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#a24c05"
      }
    },
    {
      "name": "Builtins, Classes, Types",
      "scope": [
        "support.class.builtin",
        "entity.name.type",
        "support.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#a24c05"
      }
    },
    {
      "name": "Numbers, Units",
      "scope": [
        "constant.numeric",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#f93d04"
      }
    },
    {
      "name": "CSS At-rules",
      "scope": [
        "keyword.control.at-rule",
        "entity.name.function.scss",
        "meta.at-rule support.type.property-name"
      ],
      "settings": {
        "foreground": "#f93d04"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#ff00d6"
      }
    },
    {
      "name": "CSS pseudo-class/element",
      "scope": [
        "entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.pseudo-element"
      ],
      "settings": {
        "foreground": "#5d8a1c"
      }
    },
    {
      "name": "Regex, Class Names (special)",
      "scope": [
        "string.regexp",
        "constant.other.color.rgb-value",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#6d3a00"
      }
    },
    {
      "name": "CSS custom properties",
      "scope": [
        "variable.css",
        "variable.argument.css",
        "variable.parameter.misc.css",
        "support.type.custom-property.css",
        "variable.other.custom-property.css",
        "source.css variable",
        "source.scss variable",
        "source.sass variable"
      ],
      "settings": {
        "foreground": "#05618f"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable.language",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#d83737"
      }
    },
    {
      "name": "Variables (non-CSS)",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#d83737"
      }
    },
    {
      "name": "Deleted, Entity",
      "scope": [
        "markup.deleted",
        "constant.character.entity",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#d83737"
      }
    },
    {
      "name": "URL, Link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#d83737"
      }
    },
    {
      "name": "Important, Bold",
      "scope": [
        "keyword.other.important",
        "markup.bold"
      ],
      "settings": {
        "foreground": "#7b5296",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Italic (markup)",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#eb007d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Template string interpolation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#eb007d"
      }
    },
    {
      "name": "Embedded expression content",
      "scope": [
        "meta.template.expression",
        "meta.embedded"
      ],
      "settings": {
        "foreground": "#222222"
      }
    },
    {
      "name": "JSON property names",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#05618f"
      }
    },
    {
      "name": "JSON string values",
      "scope": [
        "string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#5d8a1c"
      }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#05618f"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#f93d04"
      }
    },
    {
      "name": "Markdown list",
      "scope": [
        "markup.list",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#a24c05"
      }
    },
    {
      "name": "Markdown quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#6b6355",
        "fontStyle": "italic"
      }
    },
    {
      "name": "TypeScript/JS type annotations",
      "scope": [
        "support.type.primitive",
        "entity.name.type.alias",
        "entity.name.type.interface",
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#a24c05"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#f93d04"
      }
    },
    {
      "name": "CSS property values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#f93d04"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "enumMember": "#05618f",
    "variable": "#d83737",
    "variable.customProperty": "#05618f",
    "variable.constant": "#7b5296",
    "variable.defaultLibrary": "#a24c05",
    "variable.parameter": "#d83737",
    "type": "#a24c05",
    "class": "#a24c05",
    "interface": "#a24c05",
    "enum": "#a24c05",
    "typeParameter": "#6d3a00",
    "function": "#7b5296",
    "method": "#7b5296",
    "decorator": "#f93d04",
    "namespace": "#a24c05",
    "property": "#05618f",
    "parameter": "#d83737"
  }
}
